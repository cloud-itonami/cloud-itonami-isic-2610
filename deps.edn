{:paths ["src"]
 ;; langgraph-clj brings langchain-clj transitively (both zero-/single-dep,
 ;; all .cljc -> portable to JVM / SCI / ClojureScript / GraalVM). It lives
 ;; in the com-junkawasaki org of this workspace. This repo is standalone
 ;; (forkable outside the workspace); the :local/root paths only resolve
 ;; inside the monorepo checkout — a standalone fork should override them
 ;; with git coordinates.
 :deps {io.github.com-junkawasaki/langgraph-clj
        {:local/root "../../kotoba-lang/langgraph"}
        io.github.kotoba-lang/robotics
        {:local/root "../../kotoba-lang/robotics"}
        ;; REAL engineering-simulation dependency (ADR-2607152000,
        ;; generalizing ADR-2607151600's automotive pilot to this
        ;; vertical): fab.simphysics (built directly inside this repo --
        ;; no sibling kami-engine-* design repo exists for fab, unlike
        ;; automotive's kami-engine-vehicle-designer pairing) actually
        ;; calls physics-2d's real world-step impulse solver for the
        ;; wire-bond pull-test simulation, instead of comparing static
        ;; self-reported fields.
        io.github.kotoba-lang/physics-2d
        {:git/url "https://github.com/kotoba-lang/physics-2d.git"
         :sha "03b6c23c8d9aa36b92a8130fd3e37fc2548b4d26"}
        ;; REAL CAD/BREP bridge (ADR-2607992500, extending
        ;; ADR-2607160000's isic-2930 digital-twin pattern -- and
        ;; ADR-2607152000/ADR-2607151600's real-engineering-simulation
        ;; pattern before it -- to this vertical): fab.cad now
        ;; actually builds+tessellates a BREP wire-bond test-specimen
        ;; envelope for a lot via org-iso-10303's brep.feature/
        ;; brep.tessellate, the SAME kernel automotive's vdesign.cad
        ;; and autoparts's autoparts.cad already depend on -- not a
        ;; new CAD kernel written for this actor. As with physics-2d
        ;; above, this vertical has no sibling design-library repo, so
        ;; the dependency is taken directly here rather than through a
        ;; paired repo the way automotive's kami-engine-vehicle-
        ;; designer dependency works. Deliberately NOT added:
        ;; kotoba-lang/webgpu (fab.scene matches its kami.webgpu.mesh
        ;; DATA shape only -- that lib is .cljs-only, real GPU
        ;; device/buffer calls, unusable in this JVM/.cljc actor repo;
        ;; see fab.scene's docstring for the same disclosed limitation
        ;; vdesign.scene/autoparts.scene document).
        io.github.kotoba-lang/org-iso-10303
        {:git/url "https://github.com/kotoba-lang/org-iso-10303.git"
         :sha "a1de3b075bcdcfbfb75c781eb88e3d07195831cf"}
        ;; Cross-actor supply-chain-linkage contract (ADR-2607999950,
        ;; extended by ADR-2607999960/ADR-2607999970, direct-ported to
        ;; the smartphone chain by ADR-2607999980): `fab.export/
        ;; pedigree-for-lot` packages a `kotoba.pedigree` record from
        ;; a lot's own real, already-simulated `fab.robotics` wire-
        ;; bond pull-test telemetry, and `fab.governor` independently
        ;; re-verifies an OPTIONAL `:upstream-ore-pedigree` (a
        ;; `cloud-itonami-isic-0729` non-ferrous-ore production-record
        ;; pedigree), embedding it via `:pedigree/upstream` when
        ;; present -- so a downstream actor (`cloud-itonami-isic-2630`)
        ;; can independently re-verify the claim as plain EDN data --
        ;; never a live network call between actors. Pinned to the
        ;; SAME SHA every other cloud-itonami-isic-* actor in this
        ;; fleet already pins (the SHA that added `:pedigree/upstream`
        ;; chaining support). A real pinned git-coordinate dep (not
        ;; :local/root), same reasoning physics-2d/org-iso-10303 above
        ;; already establish, so this repo stays forkable standalone
        ;; outside the monorepo.
        io.github.kotoba-lang/pedigree
        {:git/url "https://github.com/kotoba-lang/pedigree.git"
         :sha "f85784211422a651fea26f448f601abfba2e7d61"}}
 :aliases
 {;; offline workspace dev -- pin transitive langchain-clj to local checkout
  :dev {:override-deps
        {io.github.com-junkawasaki/langchain-clj
         {:local/root "../../kotoba-lang/langchain"}}}
  ;; clojure -M:dev:run  -> drive the demo through one OperationActor
  :run {:main-opts ["-m" "fab.sim"]}
  :test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}
  ;; ADR-2607999980's critical end-to-end proof: a GENUINE cross-repo
  ;; call into cloud-itonami-isic-0729's own `nonferrousops.export`/
  ;; `nonferrousops.store` (a real production record, actually written
  ;; and read back through that repo's OWN store, -> a real kotoba.
  ;; pedigree record), fed as plain EDN into this actor's governor.
  ;; Kept out of the default :test alias (and its own test-cross-
  ;; repo/ source root) so plain `clojure -M:dev:test` never REQUIRES
  ;; a same-org sibling checkout that a casual fork of just this repo
  ;; would not have -- the same workspace-sibling :local/root
  ;; convention `io.github.kotoba-lang/robotics` above already uses,
  ;; one org level up instead of across orgs (the same convention
  ;; `steelworks`'s own `:cross-repo-test` alias already established
  ;; for its own isic-0710 dependency, one link earlier in the
  ;; automotive chain this repo direct-ports). Still no live network
  ;; call at runtime: this is a build-time classpath dependency
  ;; exercised by tests, the same category as every other :local/root
  ;; dep in this fleet.
  :cross-repo-test
  {:extra-paths ["test-cross-repo"]
   :extra-deps {io.github.cognitect-labs/test-runner
                {:git/tag "v0.5.1" :git/sha "dfb30dd"}
                io.github.cloud-itonami/cloud-itonami-isic-0729
                {:local/root "../cloud-itonami-isic-0729"}}
   :main-opts ["-m" "cognitect.test-runner" "-d" "test-cross-repo"]
   :exec-fn cognitect.test-runner.api/test}
  ;; static analysis -- clj-kondo from deps (no binary), errors fail CI.
  :lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
         :main-opts    ["-m" "clj-kondo.main"
                        "--lint" "src" "test" "test-cross-repo"
                        "--fail-level" "error"]}}}
